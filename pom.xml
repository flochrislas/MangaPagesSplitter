<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>flochrislas</groupId>
  <organization>
    <name>ArdaCreation</name>
  </organization>
  <inceptionYear>2025</inceptionYear>
  <description>Tool to split double page manga spreads into single pages</description>
  <artifactId>MangaPagesSplitter</artifactId>
  <version>2.2.2</version>
  <packaging>jar</packaging>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <skip.signing>true</skip.signing>
    <app.version>${project.version}</app.version>
  </properties>

  <dependencies>
    <!-- RAR file handling -->
    <dependency>
      <groupId>com.github.junrar</groupId>
      <artifactId>junrar</artifactId>
      <version>7.5.5</version>
    </dependency>
    <!-- Modern Swing Look and Feel with dark/light themes -->
    <dependency>
      <groupId>com.formdev</groupId>
      <artifactId>flatlaf</artifactId>
      <version>3.7</version>
    </dependency>
  </dependencies>

  <profiles>
    <!-- Use this profile in order to sign the app -->
    <!-- mvn package -Psign-exe -Dsigning.keystore=path\to\keystore.pfx -Dsigning.storepass=password -->
    <profile>
      <id>sign-exe</id>
      <properties>
        <skip.signing>false</skip.signing>
      </properties>
    </profile>
  </profiles>

  <build>
    <plugins>
      <!-- This is enough to run the program with IntelliJ -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.14.0</version>
        <configuration>
          <!-- Replace source/target with release flag -->
          <release>8</release>
          <!-- Add this to suppress specific warnings if needed -->
          <compilerArgs>
            <arg>-Xlint:all,-options,-path</arg>
          </compilerArgs>
        </configuration>
      </plugin>
      <!-- Allows to build the application as a JAR file -->
      <plugin>
        <artifactId>maven-assembly-plugin</artifactId>
        <configuration>
          <archive>
            <manifest>
              <mainClass>MangaPagesSplitter</mainClass>
            </manifest>
          </archive>
          <descriptorRefs>
            <descriptorRef>jar-with-dependencies</descriptorRef>
          </descriptorRefs>
        </configuration>
        <executions>
          <execution>
            <id>make-assembly</id>
            <phase>package</phase>
            <goals>
              <goal>single</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
      <!-- Stage the fat JAR alone into a clean folder for jpackage's input arg.
           jpackage copies every file from its input dir into the app's "app"
           folder, so we point it at a directory containing only the fat JAR. -->
      <plugin>
        <artifactId>maven-resources-plugin</artifactId>
        <version>3.3.1</version>
        <executions>
          <execution>
            <id>stage-jar-for-jpackage</id>
            <phase>package</phase>
            <goals>
              <goal>copy-resources</goal>
            </goals>
            <configuration>
              <outputDirectory>${project.build.directory}/jpackage-input</outputDirectory>
              <resources>
                <resource>
                  <directory>${project.build.directory}</directory>
                  <includes>
                    <include>${project.artifactId}-${app.version}-jar-with-dependencies.jar</include>
                  </includes>
                </resource>
              </resources>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <!-- Allows to execute external program during maven build -->
      <!-- Used to (1) build a self-contained Windows app image with jpackage
           and (2) optionally sign the resulting EXE with signtool. -->
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.5.0</version>
        <executions>
          <!-- Build a self-contained Windows app-image (launcher EXE + bundled JRE).
               Replaces the previous launch4j-based EXE, which triggered antivirus
               false positives (Bitdefender Advanced Threat Defense, etc.) because
               malware authors abuse the same launch4j stub. -->
          <execution>
            <id>jpackage</id>
            <phase>package</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <executable>jpackage</executable>
              <arguments>
                <argument>--type</argument>
                <argument>app-image</argument>
                <argument>--name</argument>
                <argument>MangaPagesSplitter</argument>
                <argument>--app-version</argument>
                <argument>${app.version}</argument>
                <argument>--vendor</argument>
                <argument>ArdaCreation</argument>
                <argument>--description</argument>
                <argument>${project.description}</argument>
                <argument>--input</argument>
                <argument>${project.build.directory}/jpackage-input</argument>
                <argument>--main-jar</argument>
                <argument>${project.artifactId}-${app.version}-jar-with-dependencies.jar</argument>
                <argument>--main-class</argument>
                <argument>MangaPagesSplitter</argument>
                <argument>--dest</argument>
                <argument>${project.build.directory}/jpackage</argument>
                <argument>--add-modules</argument>
                <argument>java.desktop,java.logging,java.naming,java.prefs,java.xml,jdk.unsupported,jdk.zipfs</argument>
              </arguments>
            </configuration>
          </execution>
          <!-- Optional Authenticode signing of the jpackage launcher EXE. -->
          <execution>
            <id>sign-exe</id>
            <phase>package</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <executable>signtool</executable>
              <arguments>
                <argument>sign</argument>
                <argument>/f</argument>
                <argument>${signing.keystore}</argument>
                <argument>/p</argument>
                <argument>${signing.storepass}</argument>
                <argument>/fd</argument>
                <argument>SHA256</argument>
                <argument>/tr</argument>
                <argument>http://timestamp.sectigo.com</argument>
                <argument>/td</argument>
                <argument>SHA256</argument>
                <argument>/d</argument>
                <argument>MangaPagesSplitter</argument>
                <argument>${project.build.directory}\jpackage\MangaPagesSplitter\MangaPagesSplitter.exe</argument>
              </arguments>
              <skip>${skip.signing}</skip>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

</project>
